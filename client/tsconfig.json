{
  "compilerOptions": {

    "module": "esnext",
    "target": "es2020",
    "lib": ["DOM", "es2020"],
    "moduleResolution": "bundler",
    "isolatedModules": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}